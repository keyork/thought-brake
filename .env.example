THOUGHT_BRAKE_API_KEY=your-api-key-here
THOUGHT_BRAKE_BASE_URL=https://your-llm-api.example/v1
THOUGHT_BRAKE_MODEL=your-reasoning-model

# Optional runtime tuning
THOUGHT_BRAKE_ENABLE=true
THOUGHT_BRAKE_DETECTOR=budget
THOUGHT_BRAKE_SOFT_BUDGET=300
THOUGHT_BRAKE_HARD_LIMIT=600
THOUGHT_BRAKE_COMPRESSION_BASELINE_CHARS=200
THOUGHT_BRAKE_COMPRESSION_RECENT_CHARS=200
THOUGHT_BRAKE_COMPRESSION_THETA_CRD=0.7
THOUGHT_BRAKE_COMPRESSION_THETA_LZ=0.5
THOUGHT_BRAKE_COMPRESSION_CONSECUTIVE_WINDOWS=2
THOUGHT_BRAKE_NGRAM_SIZE=4
THOUGHT_BRAKE_NGRAM_WINDOW_CHARS=200
THOUGHT_BRAKE_NGRAM_THRESHOLD=0.6
THOUGHT_BRAKE_NGRAM_CONSECUTIVE_WINDOWS=2
THOUGHT_BRAKE_KEYWORD_WINDOW_CHARS=300
THOUGHT_BRAKE_KEYWORD_TRIGGER_THRESHOLD=0.03
THOUGHT_BRAKE_KEYWORD_CONSECUTIVE_WINDOWS=2
THOUGHT_BRAKE_SEMANTIC_WINDOW_CHARS=200
THOUGHT_BRAKE_SEMANTIC_JACCARD_THRESHOLD=0.35
THOUGHT_BRAKE_SEMANTIC_CONSECUTIVE_WINDOWS=2
THOUGHT_BRAKE_SEMANTIC_MIN_WORDS=5
THOUGHT_BRAKE_FINALIZE_HINT="\n\n好，已经想清楚了，直接给出最终答案。"
THOUGHT_BRAKE_REASONING_START_TAG="<think>\n"
THOUGHT_BRAKE_REASONING_END_TAG="\n</think>\n\n"
THOUGHT_BRAKE_FINAL_ANSWER_PROMPT="只输出最终答案。不要复述推理过程，不要列分析步骤，不要提到你已经思考。"
THOUGHT_BRAKE_CLEAN_PHASE2_ANSWER=true
THOUGHT_BRAKE_PHASE2_MODE=direct
THOUGHT_BRAKE_PHASE2_DISABLE_THINKING=true
THOUGHT_BRAKE_PHASE2_EXTRA_BODY='{"enable_thinking": false}'
THOUGHT_BRAKE_PHASE2_DIRECT_CONVERSATION_CHARS=1200
THOUGHT_BRAKE_PHASE2_DIRECT_HEAD_CHARS=150
THOUGHT_BRAKE_PHASE2_DIRECT_TAIL_CHARS=200
THOUGHT_BRAKE_PHASE2_SKIP_USER_PROMPT=false
THOUGHT_BRAKE_PHASE2_TEMPERATURE=-1
THOUGHT_BRAKE_PHASE2_MAX_TOKENS=0
THOUGHT_BRAKE_SENTENCE_END_PATTERN="[。！？!?\n]"
THOUGHT_BRAKE_FALLBACK_EXCERPT_CHARS=300
THOUGHT_BRAKE_FALLBACK_ASSISTANT_TEMPLATE="[已思考]: {reasoning}..."
THOUGHT_BRAKE_FALLBACK_USER_PROMPT="请直接给出最终答案，简明扼要。"
THOUGHT_BRAKE_FALLBACK_ON_PHASE2_FAIL=true
